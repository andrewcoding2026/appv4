<?xml version="1.0" encoding="utf-8"?>
<!--
    Explicit data-extraction rules (API 31+, used when allowBackup is re-enabled).
    The Room database "NFCSecurity.db" and its WAL/SHM journals must never be backed up
    because they contain AES-256-GCM ciphertext whose confidentiality depends on the key
    remaining inside the device's AndroidKeyStore (hardware-backed, non-exportable).
    Backing up the ciphertext blob would allow offline brute-force if the backup itself is
    compromised, even though the key cannot be extracted.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="NFCSecurity.db" />
        <exclude domain="database" path="NFCSecurity.db-wal" />
        <exclude domain="database" path="NFCSecurity.db-shm" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="NFCSecurity.db" />
        <exclude domain="database" path="NFCSecurity.db-wal" />
        <exclude domain="database" path="NFCSecurity.db-shm" />
    </device-transfer>
</data-extraction-rules>